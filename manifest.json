{
  "manifest_version": 3,
  "name": "Streak Guardian",
  "version": "1.0.0",
  "description": "Keeps my GitHub streak honest.",
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["alarms", "storage", "notifications"],
  "icons": {
    "128": "icon.png"
  }
}